{
  "name": "lora-maker",
  "version": "1.0.0",
  "description": "LoRA 학습 도구",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.loramaker.app",
    "productName": "LoRA Maker",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": [
          "app.py",
          "server/**",
          "config/**",
          "static/**",
          "templates/**",
          "requirements.txt",
          "data/**",
          "kohya-sd-scripts/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
